{
  "Routes": [
    // GET products
    {
      "UpstreamHttpMethod": [ "Get" ],
      "UpstreamPathTemplate": "/products",
      "DownstreamPathTemplate": "/api/products",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5001
        }
      ],
      "CacheOptions": {
        "TtlSeconds": 60,
        "Region": "default",
        "Header": "eCommerce-Cache-Control"
      }
    },
    // GET product by Id
    {
      "UpstreamHttpMethod": [ "Get" ],
      "UpstreamPathTemplate": "/products/{id}",
      "DownstreamPathTemplate": "/api/products/{id}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5001
        }
      ],
      "CacheOptions": {
        "TtlSeconds": 60,
        "Region": "default",
        "Header": "eCommerce-Cache-Control"
      }
    },
    // POST, PUT, DELETE product
    {
      "UpstreamHttpMethod": [ "POST", "PUT", "DELETE" ],
      "UpstreamPathTemplate": "/products/{id}",
      "DownstreamPathTemplate": "/api/products/{id}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5001
        }
      ],
      "AuthenticationOptions": {
        "AuthenticationProviderKeys": [ "Bearer" ],
        "AllowedScopes": []
      }
    },
    // Authentication
    {
      "UpstreamHttpMethod": [ "Get", "POST" ],
      "UpstreamPathTemplate": "/authentication/{everything}",
      "DownstreamPathTemplate": "/api/authentication/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5000
        }
      ],
      "RateLimitOptions": {
        "ClientIdHeader": "ClientId",
        "Limit": 1,
        "Period": "30s",
        "EnableRateLimiting": true,
        "ClientWhitelist": []
      }
    },
    // POST, PUT, DELETE order
    {
      "UpstreamHttpMethod": [ "POST", "PUT", "DELETE" ],
      "UpstreamPathTemplate": "/orders/{id}",
      "DownstreamPathTemplate": "/api/orders/{id}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5002
        }
      ],
      "AuthenticationOptions": {
        "AuthenticationProviderKeys": [ "Bearer" ],
        "AllowedScopes": []
      }
    },
    // GET order
    {
      "UpstreamHttpMethod": [ "GET" ],
      "UpstreamPathTemplate": "/orders",
      "DownstreamPathTemplate": "/api/orders",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5002
        }
      ],
      "CacheOptions": {
        "TtlSeconds": 60,
        "Region": "default",
        "Header": "eCommerce-Cache-Control"
      },
      "AuthenticationOptions": {
        "AuthenticationProviderKeys": [ "Bearer" ],
        "AllowedScopes": []
      }
    },
    // GET order by Id
    {
      "UpstreamHttpMethod": [ "GET" ],
      "UpstreamPathTemplate": "/orders/{id}",
      "DownstreamPathTemplate": "/api/orders/{id}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5002
        }
      ],
      "CacheOptions": {
        "TtlSeconds": 60,
        "Region": "default",
        "Header": "eCommerce-Cache-Control"
      },
      "AuthenticationOptions": {
        "AuthenticationProviderKeys": [ "Bearer" ],
        "AllowedScopes": []
      }
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5003"    
  }
}